# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# WordPress
WP_URL=https://your-site.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# Posting schedule (24h format, comma-separated)
POST_TIMES=08:00,13:00,20:00

# Article settings
ARTICLE_LANGUAGE=Japanese
ARTICLE_MIN_CHARS=1500
